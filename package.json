{
  "name": "@plone/nick",
  "description": "Nearly Headless CMS",
  "type": "module",
  "maintainers": [
    {
      "name": "Plone Foundation",
      "email": "plone-developers@lists.sourceforge.net",
      "url": "http://plone.org"
    }
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./*": {
      "import": "./*",
      "require": "./*"
    }
  },
  "license": "MIT",
  "version": "2.8.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:plone/nick.git"
  },
  "bugs": {
    "url": "https://github.com/plone/nick/issues",
    "email": "plone-developers@lists.sourceforge.net"
  },
  "homepage": "https://nick.docs.plone.org",
  "keywords": [
    "cms"
  ],
  "scripts": {
    "bootstrap": "pnpm install && pnpm create-config && pnpm migrate && pnpm seed",
    "coverage": "AUTH_RATE_LIMIT=1000 vitest --coverage",
    "convert": "tsx scripts/convert.ts",
    "export": "tsx scripts/export.ts",
    "create-config": "cp -n config.ts.sample config.ts",
    "i18n": "tsx scripts/i18n.ts",
    "i18n:ci": "pnpm i18n && git diff -G'^[^\"POT]' --exit-code",
    "knex": "tsx ./node_modules/knex/bin/cli.js",
    "lint": "./node_modules/eslint/bin/eslint.js --max-warnings=0 'src/**/*.{js,ts,json}' 'scripts/**/*.{js,ts,json}'",
    "migrate": "pnpm knex migrate:latest",
    "migrate:list": "pnpm knex migrate:list",
    "prettier": "./node_modules/.bin/prettier --single-quote --check 'src/**/*.{js,ts,json}' 'scripts/**/*.{js,ts,json}'",
    "seed": "tsx scripts/seed.ts run",
    "seed:status": "tsx scripts/seed.ts status",
    "seed:upgrade": "tsx scripts/seed.ts upgrade",
    "start": "pnpm migrate:list && pnpm seed:status && nodemon --exec 'tsx src/server.ts'",
    "rollback": "pnpm knex migrate:rollback --all",
    "reset": "pnpm rollback && pnpm migrate && pnpm seed",
    "test": "AUTH_RATE_LIMIT=1000 vitest"
  },
  "engines": {
    "node": "^22 || ^24 || ^25 || ^26"
  },
  "prettier": {
    "trailingComma": "all",
    "singleQuote": true
  },
  "devDependencies": {
    "@babel/core": "8.0.0-rc.6",
    "@babel/plugin-transform-typescript": "8.0.0-rc.6",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/du": "1.0.3",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/mime-types": "3.0.1",
    "@types/node": "25.9.2",
    "@types/nodemailer": "8.0.0",
    "@types/pdf-parse": "1.1.5",
    "@types/supertest": "7.2.0",
    "@types/turndown": "5.0.6",
    "@vitest/coverage-v8": "5.0.0-beta.2",
    "@vitest/ui": "5.0.0-beta.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "glob": "13.0.6",
    "jiti": "2.7.0",
    "pofile": "1.1.4",
    "prettier": "3.8.4",
    "supertest": "7.2.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "5.0.0-beta.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1065.0",
    "@formatjs/cli": "6.16.10",
    "@formatjs/intl": "4.1.13",
    "bcrypt": "6.0.0",
    "bcrypt-promise": "2.0.0",
    "dayjs": "1.11.21",
    "du": "1.0.0",
    "es-toolkit": "1.47.0",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "knex": "3.2.10",
    "log4js": "6.9.1",
    "mime-types": "3.0.2",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.11",
    "nodemon": "3.1.14",
    "objection": "3.1.5",
    "pdf-parse": "2.4.5",
    "pg": "8.21.0",
    "sharp": "0.34.5",
    "slugify": "1.6.9",
    "turndown": "7.2.4",
    "tsx": "4.22.4",
    "uuid": "14.0.0",
    "xss": "1.0.15"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
