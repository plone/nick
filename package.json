{
  "name": "@robgietema/nick",
  "description": "Nearly Headless CMS",
  "type": "module",
  "maintainers": [
    {
      "name": "Rob Gietema",
      "email": "rob.gietema@gmail.com",
      "url": "https://robgietema.nl"
    }
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./*": {
      "import": "./*",
      "require": "./*"
    }
  },
  "license": "MIT",
  "version": "2.8.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:robgietema/nick.git"
  },
  "bugs": {
    "url": "https://github.com/robgietema/nick/issues",
    "email": "info@nickcms.org"
  },
  "homepage": "https://nickcms.org",
  "keywords": [
    "cms"
  ],
  "scripts": {
    "bootstrap": "pnpm install && pnpm create-config && pnpm migrate && pnpm seed",
    "coverage": "AUTH_RATE_LIMIT=1000 vitest --coverage",
    "convert": "tsx scripts/convert.ts",
    "export": "tsx scripts/export.ts",
    "create-config": "cp -n config.ts.sample config.ts",
    "i18n": "tsx scripts/i18n.ts",
    "i18n:ci": "pnpm i18n && git diff -G'^[^\"POT]' --exit-code",
    "knex": "tsx ./node_modules/knex/bin/cli.js",
    "lint": "./node_modules/eslint/bin/eslint.js --max-warnings=0 'src/**/*.{js,ts,json}' 'scripts/**/*.{js,ts,json}'",
    "migrate": "pnpm knex migrate:latest",
    "migrate:list": "pnpm knex migrate:list",
    "prettier": "./node_modules/.bin/prettier --single-quote --check 'src/**/*.{js,ts,json}' 'scripts/**/*.{js,ts,json}'",
    "seed": "tsx scripts/seed.ts run",
    "seed:status": "tsx scripts/seed.ts status",
    "seed:upgrade": "tsx scripts/seed.ts upgrade",
    "start": "pnpm migrate:list && pnpm seed:status && nodemon --exec 'tsx src/server.ts'",
    "rollback": "pnpm knex migrate:rollback --all",
    "reset": "pnpm rollback && pnpm migrate && pnpm seed",
    "test": "AUTH_RATE_LIMIT=1000 vitest"
  },
  "engines": {
    "node": "^22 || ^24 || ^25 || ^26"
  },
  "prettier": {
    "trailingComma": "all",
    "singleQuote": true
  },
  "devDependencies": {
    "@babel/core": "8.0.0-rc.6",
    "@babel/plugin-transform-typescript": "8.0.0-rc.6",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/du": "1.0.3",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/mime-types": "3.0.1",
    "@types/node": "25.9.1",
    "@types/nodemailer": "8.0.0",
    "@types/pdf-parse": "1.1.5",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "5.0.0-beta.2",
    "@vitest/ui": "5.0.0-beta.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "glob": "13.0.6",
    "jiti": "2.7.0",
    "pofile": "1.1.4",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "5.0.0-beta.2"
  },
  "dependencies": {
    "@formatjs/cli": "6.16.6",
    "@formatjs/intl": "4.1.12",
    "bcrypt": "6.0.0",
    "bcrypt-promise": "2.0.0",
    "dayjs": "1.11.21",
    "du": "1.0.0",
    "es-toolkit": "1.47.0",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "knex": "3.2.10",
    "log4js": "6.9.1",
    "mime-types": "3.0.2",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.10",
    "nodemon": "3.1.14",
    "objection": "3.1.5",
    "pdf-parse": "2.4.5",
    "pg": "8.21.0",
    "sharp": "0.34.5",
    "slugify": "1.6.9",
    "tsx": "4.22.4",
    "uuid": "14.0.0"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
